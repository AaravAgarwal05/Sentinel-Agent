# ============================================================================
# Sentinel Agent .gitignore
# ============================================================================
# Production-level ignore rules. Organized by category. Patterns marked
# with a leading "!" are explicit "do track this" overrides.
# ============================================================================

# ----- Byte-compiled / optimized / DLL files -------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.manifest
cython_debug/

# ----- Distribution / packaging --------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
pip-wheel-metadata/

# ----- Virtual environments ------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
.python-install/
.python-venv/
# Local per-project poetry config (lockfile is tracked; toml is local)
poetry.toml
# Pipenv / PDM / Hatch
Pipfile.lock
Pipfile
.pdm.toml
.pdm-python/
.hatch/
hatch.toml

# ----- Tests / coverage ----------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/
.cache/
# CI / test artifact directories
junit/
test-results/
.tmp-test*/

# ----- Type checkers / linters --------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
mypy_report.txt
.pyre/
.pytype/
.ruff_cache/
.pyright/
.bandit/

# ----- Jupyter ------------------------------------------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ----- Environment / secrets ----------------------------------------------
.env
.env.*
!.env.example
.envrc
.python_env
venv.bak/

# ----- Logs / runtime ------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock
celerybeat-schedule
celerybeat-schedule.dir
*.sock

# ----- Local databases (SQLite, etc.) -------------------------------------
# Project default writes sentinel_agent.db at the repo root.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite3-journal
instance/
data/
*.mdb

# ----- OS / editor ---------------------------------------------------------
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.swp
*.swo
*~
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.fleet/
.cursor/
.aider*
.history/
.atom/
.directory
nohup.out

# ----- Documentation builds ------------------------------------------------
docs/_build/
docs/build/
docs/_site/
_site/
site/
*.mdx-output/
.bible/

# ----- Docker --------------------------------------------------------------
docker-compose.override.yml
docker-compose.*.yml
!.dockerignore
.docker/
*.tar
*.tgz
*.tar.gz

# ----- Helm / Kubernetes ---------------------------------------------------
charts/*/charts/
charts/*/Chart.lock
charts/*/requirements.lock
*.tgz
*.tar.gz
helm-releases/
*.kubeconfig
.kube/

# ----- Cloud / infrastructure ----------------------------------------------
# Terraform
.terraform.lock.hcl
crash.log
crash.*.log
terraform.rc
# Pulumi
Pulumi.*.yaml
# Ansible
*.retry
# SOPS / encryption
.sops.yaml
.sops.yml
*.age
.secret/
.vault/
vault_*
# kOps
kops-*.yaml

# ----- Build / cache -------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej
.local/
.webassets-cache/
.scrapy/
.tox/

# ----- Secrets / keys ------------------------------------------------------
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
secrets/
.ansible/
.terraform/
*.tfstate
*.tfstate.*

# ----- CI / CD -------------------------------------------------------------
.teamcity/
.gradle/
buildNumber.properties
# GitHub Actions local runners
.ACTIONS_RUNTIME_TOKEN
.ACTIONS_CACHE_URL
# Jenkins
workspace/
config.xml
*.junit

# ----- Profiling / debug ---------------------------------------------------
*.prof
*.lprof
.pgviz/
callgrind.out.*
perf.data*
massif.out.*
.tracy/
flamegraph.svg
benchmark/
*.bench
*.benchmark
*.stats

# ----- AI / assistant tooling ----------------------------------------------
# Claude Code local session data and configuration.
.claude/
# Allow repo-level instructions if anyone ever adds one.
!.claude/CLAUDE.md
!.claude/settings.json
# Claude Flow runtime data and workflow scripts (local artifacts).
.claude-flow/
# Other AI assistants.
.aider.chat.history.md
.continue/
.cody/
.windsurfrules

# ----- Agent-specific runtime ----------------------------------------------
# Local SQLite file written by the default StorageConfig.
sentinel_agent.db
sentinel_agent.db-shm
sentinel_agent.db-wal
# Local kubeconfig / cluster state if the agent ever shells out.
agent_state/